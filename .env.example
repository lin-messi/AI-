# 复制本文件为 .env，填入你自己的 Key（.env 已被 git 忽略，不会上传）
# 默认使用 DeepSeek；改成任意 OpenAI 兼容服务也可以（智谱/OpenAI/Moonshot 等）。

# 必填：你的 API Key（留空则不翻译，新闻保持英文原文）
AI_API_KEY=

# 选填：接口地址（默认 DeepSeek）
AI_BASE_URL=https://api.deepseek.com

# 选填：模型名（DeepSeek 用 deepseek-chat；智谱可用 glm-4-flash 等）
AI_MODEL=deepseek-chat

# —— 其他兼容服务示例（按需替换上面三项）——
# 智谱 GLM:    AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4   AI_MODEL=glm-4-flash
# OpenAI:      AI_BASE_URL=https://api.openai.com/v1             AI_MODEL=gpt-4o-mini
# Moonshot:    AI_BASE_URL=https://api.moonshot.cn/v1            AI_MODEL=moonshot-v1-8k
